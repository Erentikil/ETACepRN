{
  "expo": {
    "name": "ETA Mobil Pro",
    "slug": "etamobilpro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon-1024-pro_3.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.horizonyazilim.etamobilpro",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "NSCameraUsageDescription": "Barkod okumak için kamera gereklidir.",
        "LSApplicationQueriesSchemes": [
          "tel",
          "telprompt",
          "whatsapp",
          "sms",
          "mailto",
          "maps",
          "comgooglemaps",
          "yandexmaps"
        ]
      }
    },
    "android": {
      "icon": "./assets/play_store_icon_512_pro_1.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.horizonyazilim.etamobilpro",
      "usesCleartextTraffic": true,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "105eb735-4ba2-4592-a9af-c4f613b2087e"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "owner": "erentikik"
  }
}
